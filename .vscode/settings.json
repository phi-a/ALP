{
  "python.defaultInterpreterPath": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
  "python.terminal.activateEnvironment": true,
  "jupyter.notebookFileRoot": "${workspaceFolder}\\missions",
  "jupyter.kernels.filter": [
    {
      "path": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "type": "pythonEnvironment"
    }
  ],
  "terminal.integrated.env.windows": {
    "JUPYTER_CONFIG_DIR": "${workspaceFolder}\\.jupyter",
    "JUPYTER_PATH": "${workspaceFolder}\\.jupyter",
    "TEMP": "${workspaceFolder}\\.tmp",
    "TMP": "${workspaceFolder}\\.tmp"
  }
}
